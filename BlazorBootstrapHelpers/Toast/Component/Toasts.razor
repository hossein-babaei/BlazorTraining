@inject ToastService ToastService

<div class="toast-container position-fixed @GetPositionClass() p-3" style="z-index: 9999;">
    @foreach (var item in _toasts)
    {
        var toast = item.Config;
        var classes = new List<string> { "toast" };
        if (toast.Animation) classes.Add("fade");
        if (item.IsShown) classes.Add("show");
        if (!string.IsNullOrEmpty(toast.CssClass)) classes.Add(toast.CssClass);

        <div class="@string.Join(' ', classes) @GetToastClass(toast.Type)" role="alert"
             aria-live="assertive" aria-atomic="true"
             style="min-width: 300px; @(toast.AutoHide ? "" : "opacity: 1;")"
             @onclick="() => RemoveToast(item)">
            <div class="toast-header @GetHeaderClass(toast.Type)">
                @if (!string.IsNullOrEmpty(toast.Icon))
                {
                    <i class="bi @toast.Icon me-2"></i>
                }
                <strong class="me-auto">@toast.Title</strong>
                @if (toast.AutoHide)
                {
                    <small class="text-muted">just now</small>
                }
                <button type="button" class="btn-close" @onclick="(e) => { e.StopPropagation(); RemoveToast(item); }" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                @toast.Message
            </div>
        </div>
    }
</div>

@code {
    private class ToastItem
    {
        public ToastConfig Config { get; set; } = default!;
        public bool IsShown { get; set; }
        public CancellationTokenSource? Cts { get; set; }
    }

    private List<ToastItem> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
        ToastService.OnClear += ClearAllToasts;
    }

    private void ShowToast(ToastConfig message)
    {
        var item = new ToastItem { Config = message, IsShown = false };
        _toasts.Add(item);
        StateHasChanged();

        // Trigger CSS transition: render first, then set IsShown = true
        _ = Task.Run(async () =>
        {
            // Small delay to ensure element is rendered so CSS transition runs
            await Task.Delay(100);
            item.IsShown = true;
            await InvokeAsync(StateHasChanged);

            if (message.AutoHide)
            {
                try
                {
                    item.Cts = new CancellationTokenSource();
                    await Task.Delay(message.AutoHideDelay, item.Cts.Token);
                    await InvokeAsync(() => HideToast(item));
                }
                catch (TaskCanceledException) { }
            }
        });
    }

    private void RemoveToast(ToastItem item)
    {
        // user-initiated remove -> hide with animation if enabled
        _ = HideToast(item);
    }

    private async Task HideToast(ToastItem item)
    {
        if (!_toasts.Contains(item)) return;

        // cancel any pending autohide
        item.Cts?.Cancel();

        if (item.Config.Animation)
        {
            // trigger hide transition
            item.IsShown = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(item.Config.AnimationDuration);
        }

        _toasts.Remove(item);
        await InvokeAsync(StateHasChanged);
    }

    private void ClearAllToasts()
    {
        _toasts.Clear();
        StateHasChanged();
    }

    private string GetToastClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-success text-white",
        ToastType.Error => "bg-danger text-white",
        ToastType.Warning => "bg-warning text-dark",
        ToastType.Info => "bg-info text-white",
        _ => ""
    };

    private string GetHeaderClass(ToastType type) => type switch
    {
        ToastType.Success => "bg-success text-white",
        ToastType.Error => "bg-danger text-white",
        ToastType.Warning => "bg-warning text-dark",
        ToastType.Info => "bg-info text-white",
        _ => ""
    };

    private string GetPositionClass() => _toasts.LastOrDefault()?.Config.Position switch
    {
        ToastPosition.TopRight => "top-0 end-0",
        ToastPosition.TopLeft => "top-0 start-0",
        ToastPosition.BottomRight => "bottom-0 end-0",
        ToastPosition.BottomLeft => "bottom-0 start-0",
        ToastPosition.TopCenter => "top-0 start-50 translate-middle-x",
        ToastPosition.BottomCenter => "bottom-0 start-50 translate-middle-x",
        _ => "bottom-0 end-0"
    };

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
        ToastService.OnClear -= ClearAllToasts;
    }
}
