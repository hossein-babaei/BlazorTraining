<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>

    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <RazorLangVersion>Latest</RazorLangVersion>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <NoWarn>$(NoWarn);1591</NoWarn>

    <PackageId>BlazorTraining.Dialog</PackageId>
    <Title>BlazorTraining.Dialog</Title>
    <Authors>Hossein Babaei</Authors>
    <Company>BlazorTraining</Company>

    <Description>
      A modern dialog framework for Blazor built on Bootstrap.
    </Description>

    <PackageTags>
      blazor;dialog;modal;bootstrap;razor
    </PackageTags>

    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>

    <IsPackable>true</IsPackable>

    <StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>

  </PropertyGroup>

  <ItemGroup>

    <FrameworkReference Include="Microsoft.AspNetCore.App" />

  </ItemGroup>

</Project>