@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@typeparam TModel where TModel : class, new()

<div class="modal fade" id="@ModalId" tabindex="-1" aria-labelledby="@ModalId" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@Model" OnValidSubmit="@OnValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    @ChildContent

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">@SaveButtonText</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لغو</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ModalId { get; set; } = "genericModal";
    [Parameter] public string Title { get; set; } = "Form";
    [Parameter] public string SaveButtonText { get; set; } = "Save";
    [Parameter] public TModel Model { get; set; } = new TModel();
    [Parameter] public RenderFragment ChildContent { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    // متد برای باز کردن Modal
    public async Task ShowAsync()
    {
        await JsRuntime.InvokeVoidAsync("bootstrapModal.show", ModalId);
    }

    // متد برای بستن Modal
    public async Task HideAsync()
    {
        await JsRuntime.InvokeVoidAsync("bootstrapModal.hide", ModalId);
    }

    [Inject] private IJSRuntime JsRuntime { get; set; }
}

@* USAGE
@page "/products"
@inject IProductService ProductService

<h3>مدیریت محصولات</h3>

<button class="btn btn-success mb-3" @onclick="OpenAddModal">افزودن محصول جدید</button>

<table class="table table-striped">
    <thead>
        <tr>
            <th>شناسه</th>
            <th>نام</th>
            <th>قیمت</th>
            <th>عملیات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in products)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>
                    <button class="btn btn-primary btn-sm" @onclick="() => OpenEditModal(product)">ویرایش</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteProduct(product.Id)">حذف</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<GenericModal @ref="modal"
              ModalId="productModal"
              Title="@modalTitle"
              TModel="Product"
              Model="@selectedProduct"
              OnValidSubmit="HandleValidSubmit"
              SaveButtonText="@saveButtonText">
    <div class="mb-3">
        <label class="form-label">نام محصول</label>
        <InputText @bind-Value="selectedProduct.Name" class="form-control" />
        <ValidationMessage For="@(() => selectedProduct.Name)" />
    </div>
    <div class="mb-3">
        <label class="form-label">قیمت</label>
        <InputNumber @bind-Value="selectedProduct.Price" class="form-control" />
        <ValidationMessage For="@(() => selectedProduct.Price)" />
    </div>
</GenericModal>

@code {
    private List<Product> products = new();
    private GenericModal<Product> modal;
    private Product selectedProduct = new();
    private string modalTitle = "افزودن محصول";
    private string saveButtonText = "ذخیره";
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetAllAsync();
    }

    private void OpenAddModal()
    {
        selectedProduct = new Product();
        modalTitle = "افزودن محصول جدید";
        saveButtonText = "ذخیره";
        isEditMode = false;
        modal.ShowAsync();
    }

    private void OpenEditModal(Product product)
    {
        selectedProduct = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Price = product.Price
        };
        modalTitle = "ویرایش محصول";
        saveButtonText = "به‌روزرسانی";
        isEditMode = true;
        modal.ShowAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (isEditMode)
        {
            await ProductService.UpdateAsync(selectedProduct);
        }
        else
        {
            await ProductService.AddAsync(selectedProduct);
        }

        products = await ProductService.GetAllAsync();
        await modal.HideAsync();
        StateHasChanged();
    }

    private async Task DeleteProduct(int id)
    {
        // منطق حذف
    }

    public class Product
    {
        public int Id { get; set; }
        [Required(ErrorMessage = "نام محصول الزامی است")]
        public string Name { get; set; }
        [Required(ErrorMessage = "قیمت الزامی است")]
        [Range(0, double.MaxValue, ErrorMessage = "قیمت باید بزرگتر از صفر باشد")]
        public decimal Price { get; set; }
    }
} *@